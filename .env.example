DB_HOST=localhost
DB_NAME=else_inventory
DB_USER=your_db_user
DB_PASS=your_db_password

# One-time setup token — required to access setup.php
# Change this to a long random string before uploading, then delete setup.php after use
SETUP_TOKEN=change_me

# IANA timezone the event runs in (e.g. America/Los_Angeles, America/Denver, Europe/Madrid).
# Shift windows, invite/token expiry, and order deadlines are entered and displayed as local
# wall-clock time — this must match the venue's timezone or those checks will be off.
APP_TIMEZONE=UTC
